<div style="padding: 20px; font-family: sans-serif">
  <h1>Todo List</h1>

  <form phx-submit="add">
    <input
      type="text"
      name="todo"
      value={@new_todo}
      placeholder="Nova tarefa"
    />
    <button type="submit">Adicionar</button>
  </form>

  <ul>
    <%= for todo <- @todos do %>
      <li><%= todo %></li>
    <% end %>
  </ul>
</div>
